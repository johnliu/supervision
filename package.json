{
  "name": "electrobun-react-tailwind-vite",
  "version": "1.0.0",
  "description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "dev:web": "vite --open /web.html",
    "hmr": "vite --port 5173",
    "build:canary": "vite build && electrobun build --env=canary",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "test:unit": "bun test src",
    "test:e2e": "playwright test",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test": "bun run typecheck && bun run test:unit && bun run check:specs && bun run test:e2e",
    "check:specs": "bun scripts/check-spec-coverage.ts",
    "playwright:install": "playwright install webkit chromium"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@pierre/diffs": "^1.2.7",
    "@pierre/trees": "1.0.0-beta.4",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electrobun": "1.18.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
